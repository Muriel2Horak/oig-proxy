#!/usr/bin/with-contenv bashio

# DNS override: oigservis.cz -> selected IP (dns_override_ip > ha_ip > auto-detect)
DNS_OVERRIDE_RAW=$(bashio::config 'dns_override_ip')
HA_IP_RAW=$(bashio::config 'ha_ip')
if [ -n "$DNS_OVERRIDE_RAW" ] && [ "$DNS_OVERRIDE_RAW" != "null" ]; then
    DNS_TARGET_RAW="$DNS_OVERRIDE_RAW"
elif [ -n "$HA_IP_RAW" ] && [ "$HA_IP_RAW" != "null" ]; then
    DNS_TARGET_RAW="$HA_IP_RAW"
else
    DNS_TARGET_RAW=$(ip -4 route get 8.8.8.8 2>/dev/null | awk '{print $7; exit}')
    if [ -z "$DNS_TARGET_RAW" ]; then
        DNS_TARGET_RAW=$(hostname -I 2>/dev/null | awk '{print $1}')
    fi
fi

# valid IPv4 check; otherwise fallback
if echo "$DNS_TARGET_RAW" | grep -Eq '^[0-9]{1,3}(\.[0-9]{1,3}){3}$'; then
    DNS_TARGET_IP="$DNS_TARGET_RAW"
else
    DNS_TARGET_IP="127.0.0.1"
fi

UPSTREAM=$(bashio::config 'dns_upstream' | tr -d '[]"' | xargs)
if [ -z "$UPSTREAM" ] || [ "$UPSTREAM" = "null" ]; then
    UPSTREAM="8.8.8.8"
fi
if ! echo "$UPSTREAM" | grep -Eq '^[0-9]{1,3}(\.[0-9]{1,3}){3}$'; then
  UPSTREAM="8.8.8.8"
fi

# Vytvořit adresář pro dnsmasq
mkdir -p /etc/dnsmasq.d

echo "server=$UPSTREAM" > /etc/dnsmasq.d/upstream.conf
echo "address=/oigservis.cz/$DNS_TARGET_IP" > /etc/dnsmasq.d/oig.conf

# spustit dnsmasq (foreground &)
/usr/sbin/dnsmasq -k --conf-dir=/etc/dnsmasq.d &

# Připravit JSON mapu: použij novou verzi z image pouze pokud je větší
if [ -f /app/sensor_map.json ]; then
  if [ -f /data/sensor_map.json ]; then
    if ! cmp -s /app/sensor_map.json /data/sensor_map.json; then
      cp /data/sensor_map.json /data/sensor_map.json.bak.$(date +%s) || true
      cp /app/sensor_map.json /data/sensor_map.json
      echo "Sensor map updated from app bundle"
    fi
  else
    cp /app/sensor_map.json /data/sensor_map.json
  fi
fi

# Env pro proxy - all 21 parameters
export TARGET_SERVER=$(bashio::config 'target_server')
export TARGET_PORT=$(bashio::config 'target_port')
export PROXY_PORT=$(bashio::config 'proxy_port')

# PROXY_MODE: online (default), hybrid, offline
PROXY_MODE_RAW=$(bashio::config 'proxy_mode')
if [ -z "$PROXY_MODE_RAW" ] || [ "$PROXY_MODE_RAW" = "null" ]; then
    PROXY_MODE_RAW="online"
fi
export PROXY_MODE=$PROXY_MODE_RAW

# CLOUD_ACK_TIMEOUT from config (default 1800.0)
CLOUD_ACK_TIMEOUT_RAW=$(bashio::config 'cloud_ack_timeout')
if [ -z "$CLOUD_ACK_TIMEOUT_RAW" ] || [ "$CLOUD_ACK_TIMEOUT_RAW" = "null" ]; then
    CLOUD_ACK_TIMEOUT_RAW=1800.0
fi
export CLOUD_ACK_TIMEOUT=$CLOUD_ACK_TIMEOUT_RAW

# HYBRID mode settings
HYBRID_RETRY_INTERVAL_RAW=$(bashio::config 'hybrid_retry_interval')
if [ -z "$HYBRID_RETRY_INTERVAL_RAW" ] || [ "$HYBRID_RETRY_INTERVAL_RAW" = "null" ]; then
    HYBRID_RETRY_INTERVAL_RAW=60
fi
export HYBRID_RETRY_INTERVAL=$HYBRID_RETRY_INTERVAL_RAW

HYBRID_FAIL_THRESHOLD_RAW=$(bashio::config 'hybrid_fail_threshold')
if [ -z "$HYBRID_FAIL_THRESHOLD_RAW" ] || [ "$HYBRID_FAIL_THRESHOLD_RAW" = "null" ]; then
    HYBRID_FAIL_THRESHOLD_RAW=1
fi
export HYBRID_FAIL_THRESHOLD=$HYBRID_FAIL_THRESHOLD_RAW

# MQTT settings
export MQTT_HOST=$(bashio::config 'mqtt_host')
export MQTT_PORT=$(bashio::config 'mqtt_port')
export MQTT_USERNAME=$(bashio::config 'mqtt_username')
export MQTT_PASSWORD=$(bashio::config 'mqtt_password')

# HA_IP (optional, auto-detected above)
HA_IP_CONFIG=$(bashio::config 'ha_ip')
if [ -z "$HA_IP_CONFIG" ] || [ "$HA_IP_CONFIG" = "null" ]; then
    export HA_IP="$DNS_TARGET_IP"
else
    export HA_IP=$HA_IP_CONFIG
fi

# DNS_OVERRIDE_IP (optional): if set, dnsmasq maps oigservis.cz to this IP
DNS_OVERRIDE_IP_CONFIG=$(bashio::config 'dns_override_ip')
if [ -z "$DNS_OVERRIDE_IP_CONFIG" ] || [ "$DNS_OVERRIDE_IP_CONFIG" = "null" ]; then
    export DNS_OVERRIDE_IP=""
else
    export DNS_OVERRIDE_IP=$DNS_OVERRIDE_IP_CONFIG
fi

# DNS upstream
export DNS_UPSTREAM=$UPSTREAM

# log_level může být string nebo list -> vezmeme první hodnotu
LOG_LEVEL_RAW=$(bashio::config 'log_level' | tr -d '[]"' | xargs | cut -d',' -f1)
[ -z "$LOG_LEVEL_RAW" ] && LOG_LEVEL_RAW="INFO"
export LOG_LEVEL=$LOG_LEVEL_RAW

# proxy_status_interval
PROXY_STATUS_INTERVAL_RAW=$(bashio::config 'proxy_status_interval')
if [ -z "$PROXY_STATUS_INTERVAL_RAW" ] || [ "$PROXY_STATUS_INTERVAL_RAW" = "null" ]; then
    PROXY_STATUS_INTERVAL_RAW=60
fi
export PROXY_STATUS_INTERVAL=$PROXY_STATUS_INTERVAL_RAW

# full_refresh_interval_hours
FULL_REFRESH_INTERVAL_RAW=$(bashio::config 'full_refresh_interval_hours')
if [ -z "$FULL_REFRESH_INTERVAL_RAW" ] || [ "$FULL_REFRESH_INTERVAL_RAW" = "null" ]; then
    FULL_REFRESH_INTERVAL_RAW=24
fi
export FULL_REFRESH_INTERVAL_H=$FULL_REFRESH_INTERVAL_RAW

# capture_payloads
CAPTURE_PAYLOADS_RAW=$(bashio::config 'capture_payloads')
if [ "$CAPTURE_PAYLOADS_RAW" = "true" ] || [ "$CAPTURE_PAYLOADS_RAW" = "1" ]; then
    export CAPTURE_PAYLOADS="true"
else
    export CAPTURE_PAYLOADS="false"
fi

# capture_raw_bytes
CAPTURE_RAW_BYTES_RAW=$(bashio::config 'capture_raw_bytes')
if [ "$CAPTURE_RAW_BYTES_RAW" = "true" ] || [ "$CAPTURE_RAW_BYTES_RAW" = "1" ]; then
    export CAPTURE_RAW_BYTES="true"
else
    export CAPTURE_RAW_BYTES="false"
fi

# capture_retention_days
CAPTURE_RETENTION_DAYS_RAW=$(bashio::config 'capture_retention_days')
if [ -z "$CAPTURE_RETENTION_DAYS_RAW" ] || [ "$CAPTURE_RETENTION_DAYS_RAW" = "null" ]; then
    CAPTURE_RETENTION_DAYS_RAW=7
fi
export CAPTURE_RETENTION_DAYS=$CAPTURE_RETENTION_DAYS_RAW

# capture_pcap
CAPTURE_PCAP_RAW=$(bashio::config 'capture_pcap')
if [ "$CAPTURE_PCAP_RAW" = "true" ] || [ "$CAPTURE_PCAP_RAW" = "1" ]; then
    export CAPTURE_PCAP="true"
else
    export CAPTURE_PCAP="false"
fi

# control_mqtt_enabled
CONTROL_MQTT_ENABLED_RAW=$(bashio::config 'control_mqtt_enabled')
if [ "$CONTROL_MQTT_ENABLED_RAW" = "true" ] || [ "$CONTROL_MQTT_ENABLED_RAW" = "1" ]; then
    export CONTROL_MQTT_ENABLED="true"
else
    export CONTROL_MQTT_ENABLED="false"
fi

# telemetry_enabled (default true)
TELEMETRY_ENABLED_RAW=$(bashio::config 'telemetry_enabled')
if [ -z "$TELEMETRY_ENABLED_RAW" ] || [ "$TELEMETRY_ENABLED_RAW" = "null" ]; then
    TELEMETRY_ENABLED_RAW="true"
fi
if [ "$TELEMETRY_ENABLED_RAW" = "true" ] || [ "$TELEMETRY_ENABLED_RAW" = "1" ]; then
    export TELEMETRY_ENABLED="true"
else
    export TELEMETRY_ENABLED="false"
fi

# Paths
export SENSOR_MAP_PATH=/data/sensor_map.json
export UNKNOWN_SENSORS_PATH=/data/unknown_sensors.json

python -u /app/main.py
